{
  "name": "AutoVision Premium Dark",
  "dataColors": [
    "#4FC3F7",
    "#E53935",
    "#FF9800",
    "#9C27B0",
    "#00C853",
    "#B0B0B0",
    "#FFFFFF"
  ],
  "background": "#121212",
  "foreground": "#FFFFFF",
  "tableAccent": "#4FC3F7",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#1E1E1E"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "fontSize": 12,
            "fontFace": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ]
      }
    },
    "card": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#1E1E1E"
              }
            },
            "transparency": 0
          }
        ],
        "categoryLabels": [
          {
            "color": {
              "solid": {
                "color": "#B0B0B0"
              }
            },
            "fontSize": 10
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "fontSize": 28
          }
        ]
      }
    },
    "barChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#4FC3F7"
              }
            }
          }
        ],
        "categoryAxis": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#B0B0B0"
              }
            }
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#B0B0B0"
              }
            }
          }
        ]
      }
    },
    "donutChart": {
      "*": {
        "legend": [
          {
            "labelColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#1E1E1E"
              }
            },
            "transparency": 0
          }
        ],
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ]
      }
    }
  }
}